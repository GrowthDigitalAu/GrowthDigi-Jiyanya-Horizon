{% doc %}
  @prompt
    I want create a modal with ask a question when prodcuts is sold out so customer submit the form 
    
    in form please add products name , it is possible make it products information in top?, this is good just add the phonu number
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
 .active_modal .product-information {
    z-index: 11;
}
  .ai-soldout-modal-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-soldout-modal-trigger-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    transition: all 0.3s ease;
  }

  .ai-soldout-modal-trigger-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-soldout-modal-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-soldout-modal-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-soldout-modal-container-{{ ai_gen_id }} {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    background-color: {{ block.settings.modal_background }};
    border-radius: {{ block.settings.modal_border_radius }}px;
    padding: 40px;
    max-width: {{ block.settings.modal_width }}px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  .ai-soldout-modal-container-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }

  .ai-soldout-modal-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .ai-soldout-modal-title-{{ ai_gen_id }} {
    color: {{ block.settings.modal_text_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0;
    flex-grow: 1;
  }

  .ai-soldout-modal-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.modal_text_color }};
    opacity: 0.7;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
    margin-left: 16px;
  }

  .ai-soldout-modal-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-soldout-modal-product-info-{{ ai_gen_id }} {
    background-color: {{ block.settings.product_info_background }};
    border-radius: {{ block.settings.product_info_border_radius }}px;
    padding: 16px;
    margin-bottom: 24px;
    border: 1px solid {{ block.settings.product_info_border }};
  }

  .ai-soldout-modal-product-label-{{ ai_gen_id }} {
    color: {{ block.settings.modal_text_color }};
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    margin-bottom: 8px;
    opacity: 0.7;
  }

  .ai-soldout-modal-product-name-{{ ai_gen_id }} {
    color: {{ block.settings.modal_text_color }};
    font-size: 18px;
    font-weight: 600;
    margin: 0;
  }

  .ai-soldout-modal-description-{{ ai_gen_id }} {
    color: {{ block.settings.modal_text_color }};
    margin-bottom: 24px;
    font-size: 14px;
    line-height: 1.5;
  }

  .ai-soldout-modal-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-soldout-modal-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-soldout-modal-label-{{ ai_gen_id }} {
    color: {{ block.settings.modal_text_color }};
    font-size: 14px;
    font-weight: 500;
  }

  .ai-soldout-modal-input-{{ ai_gen_id }},
  .ai-soldout-modal-textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: 14px;
    width: 100%;
  }

  .ai-soldout-modal-input-{{ ai_gen_id }}:focus,
  .ai-soldout-modal-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border }};
  }

  .ai-soldout-modal-textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-soldout-modal-submit-{{ ai_gen_id }} {
    padding: 14px 28px;
    background-color: {{ block.settings.submit_background }};
    color: {{ block.settings.submit_text_color }};
    border: none;
    border-radius: {{ block.settings.submit_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .ai-soldout-modal-submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.submit_hover_background }};
  }

  .ai-soldout-modal-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 16px;
    font-size: 14px;
  }

  .ai-soldout-modal-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 8px;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-soldout-modal-container-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-soldout-modal-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<soldout-question-modal-{{ ai_gen_id }} class="ai-soldout-modal-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <button class="ai-soldout-modal-trigger-{{ ai_gen_id }}" type="button">
    {{ block.settings.button_label }}
  </button>

  <div class="ai-soldout-modal-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-soldout-modal-container-{{ ai_gen_id }}">
    <div class="ai-soldout-modal-header-{{ ai_gen_id }}">
      <h2 class="ai-soldout-modal-title-{{ ai_gen_id }}">{{ block.settings.modal_title }}</h2>
      <button class="ai-soldout-modal-close-{{ ai_gen_id }}" type="button" aria-label="Close modal">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="ai-soldout-modal-product-info-{{ ai_gen_id }}">
      <div class="ai-soldout-modal-product-label-{{ ai_gen_id }}">{{ block.settings.product_field_label }}</div>
      <h3 class="ai-soldout-modal-product-name-{{ ai_gen_id }}">{{ product.title }}</h3>
    </div>

    {% if block.settings.modal_description != blank %}
      <div class="ai-soldout-modal-description-{{ ai_gen_id }}">
        {{ block.settings.modal_description }}
      </div>
    {% endif %}

    {%- form 'contact' -%}
      <input type="hidden" name="contact[product_name]" value="{{ product.title }}">
      <input type="hidden" name="contact[product_url]" value="{{ shop.url }}{{ product.url }}">
      
      <div class="ai-soldout-modal-form-{{ ai_gen_id }}">
        <div class="ai-soldout-modal-field-{{ ai_gen_id }}">
          <label class="ai-soldout-modal-label-{{ ai_gen_id }}" for="ai-soldout-name-{{ ai_gen_id }}">
            {{ block.settings.name_label }}
          </label>
          <input
            type="text"
            id="ai-soldout-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-soldout-modal-input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.name_placeholder }}"
            required
          >
        </div>

        <div class="ai-soldout-modal-field-{{ ai_gen_id }}">
          <label class="ai-soldout-modal-label-{{ ai_gen_id }}" for="ai-soldout-email-{{ ai_gen_id }}">
            {{ block.settings.email_label }}
          </label>
          <input
            type="email"
            id="ai-soldout-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-soldout-modal-input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="{{ block.settings.email_placeholder }}"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-soldout-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-soldout-success-{{ ai_gen_id }}"
            {% endif %}
            required
          >
          {%- if form.errors -%}
            <div id="ai-soldout-error-{{ ai_gen_id }}" class="ai-soldout-modal-error-{{ ai_gen_id }}">
              {{ form.errors.messages.email }}
            </div>
          {%- endif -%}
        </div>

        <div class="ai-soldout-modal-field-{{ ai_gen_id }}">
          <label class="ai-soldout-modal-label-{{ ai_gen_id }}" for="ai-soldout-phone-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}
          </label>
          <input
            type="tel"
            id="ai-soldout-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-soldout-modal-input-{{ ai_gen_id }}"
            autocomplete="tel"
            placeholder="{{ block.settings.phone_placeholder }}"
          >
        </div>

        <div class="ai-soldout-modal-field-{{ ai_gen_id }}">
          <label class="ai-soldout-modal-label-{{ ai_gen_id }}" for="ai-soldout-question-{{ ai_gen_id }}">
            {{ block.settings.question_label }}
          </label>
          <textarea
            id="ai-soldout-question-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-soldout-modal-textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.question_placeholder }}"
            required
          ></textarea>
        </div>

        <button type="submit" class="ai-soldout-modal-submit-{{ ai_gen_id }}">
          {{ block.settings.submit_button_label }}
        </button>

        {%- if form.posted_successfully? -%}
          <div id="ai-soldout-success-{{ ai_gen_id }}" class="ai-soldout-modal-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}
      </div>
    {%- endform -%}
  </div>
</soldout-question-modal-{{ ai_gen_id }}>

<script>
  (function() {
    class SoldoutQuestionModal{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.trigger = this.querySelector('.ai-soldout-modal-trigger-{{ ai_gen_id }}');
        this.overlay = this.querySelector('.ai-soldout-modal-overlay-{{ ai_gen_id }}');
        this.container = this.querySelector('.ai-soldout-modal-container-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-soldout-modal-close-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.trigger.addEventListener('click', () => this.openModal());
        this.closeButton.addEventListener('click', () => this.closeModal());
        this.overlay.addEventListener('click', () => this.closeModal());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.container.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      openModal() {
        this.overlay.classList.add('active');
        this.container.classList.add('active');
        document.body.style.overflow = 'hidden';
        document.body.classList.add('active_modal');
      }

      closeModal() {
        this.overlay.classList.remove('active');
        this.container.classList.remove('active');
        document.body.style.overflow = '';
        document.body.classList.remove('active_modal');
      }
    }

    customElements.define('soldout-question-modal-{{ ai_gen_id }}', SoldoutQuestionModal{{ ai_gen_id }});
  })();
</script>

